{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "overlay-chat",
  "version": "0.1.0",
  "identifier": "com.james.overlay-chat",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "overlay-chat",
        "width": 380,
        "height": 600,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true
      },
      {
        "label": "hud",
        "title": "game-guidance-hud",
        "url": "hud.html",
        "x": -32000,
        "y": -32000,
        "width": 1,
        "height": 1,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focusable": false,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/api_server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
