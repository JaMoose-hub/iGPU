{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "overlay-chat",
  "version": "0.1.0",
  "identifier": "com.james.overlay-chat",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "overlay-chat",
        "width": 520,
        "height": 620,
        "minWidth": 460,
        "minHeight": 560,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true
      },
      {
        "label": "hud",
        "title": "game-guidance-hud",
        "url": "hud.html",
        "x": -32000,
        "y": -32000,
        "width": 1,
        "height": 1,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focusable": false,
        "visible": false,
        "resizable": false
      },
      {
        "label": "tasks",
        "title": "game-task-log",
        "url": "tasks.html",
        "x": -32000,
        "y": -32000,
        "width": 380,
        "height": 560,
        "minWidth": 340,
        "minHeight": 420,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": true
      },
      {
        "label": "search",
        "title": "game-search",
        "url": "search.html",
        "x": -32000,
        "y": -32000,
        "width": 960,
        "height": 720,
        "minWidth": 620,
        "minHeight": 520,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
